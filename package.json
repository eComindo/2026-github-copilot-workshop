{
  "name": "001-core-procurement-system",
  "version": "1.0.0",
  "description": "Hands-on 5-hour workshop to build a web-based procurement MVP and practice Copilot across SDLC.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "test": "npm run test:unit",
    "test:unit": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "cd backend && npm run test:coverage",
    "test:coverage:frontend": "cd frontend && npm run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:e2e:ui": "playwright test --ui"
  },
  "author": "Arie M. Prasetyo",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1"
  }
}
